OLLAMA_BASE_URL=http://localhost:11434
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/rag_db
EMBEDDING_MODEL=nomic-embed-text:latest
CHAT_MODEL=qwen3:8b
# Optional alternate: llama3.2:latest
EMBEDDING_DIMENSION=768
TOP_K=5
GRAPHRAG_ENABLED=true
GRAPHRAG_ENTITY_TOP_K=8
GRAPHRAG_RELATION_TOP_K=16
GRAPHRAG_CHUNK_TOP_K=8
GRAPHRAG_EXTRACTION_MODEL=
GRAPHRAG_EXTRACTION_TIMEOUT_SECONDS=45
